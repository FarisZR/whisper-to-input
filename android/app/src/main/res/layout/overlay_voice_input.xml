<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="332dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_voice_overlay"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="14dp"
    android:paddingEnd="18dp"
    android:paddingBottom="18dp">

    <View
        android:id="@+id/view_drag_handle_touch"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:background="@android:color/transparent"
        android:paddingTop="4dp"
        android:paddingBottom="8dp" />

    <View
        android:layout_width="54dp"
        android:layout_height="6dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="-14dp"
        android:background="@drawable/bg_voice_overlay_handle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/overlay_language_icon"
            android:src="@drawable/ic_overlay_globe"
            android:tint="@color/overlay_foreground" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btn_overlay_close"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/overlay_close"
            android:padding="2dp"
            android:src="@drawable/ic_overlay_close"
            android:tint="@color/overlay_foreground" />
    </LinearLayout>

    <com.example.whispertoinput.accessibility.WaveformView
        android:id="@+id/waveform_view"
        android:layout_width="match_parent"
        android:layout_height="132dp"
        android:layout_marginTop="8dp" />

    <View
        android:id="@+id/view_transcribing_indicator"
        android:layout_width="72dp"
        android:layout_height="3dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="-12dp"
        android:background="@drawable/bg_voice_overlay_indicator"
        android:visibility="gone" />

    <TextView
        android:id="@+id/label_overlay_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="14dp"
        android:fontFamily="sans-serif-medium"
        android:text="@string/overlay_recording"
        android:textColor="@color/overlay_foreground"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/label_overlay_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="4dp"
        android:fontFamily="sans-serif"
        android:text="Auto detect"
        android:textColor="@color/overlay_foreground_secondary"
        android:textSize="15sp" />
</LinearLayout>
