<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/keyboard_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_alignParentBottom="true"
    android:layout_gravity="bottom"
    android:background="@color/keyboard_background"
    android:clipToPadding="false"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingBottom="8dp">

    <!-- Accent top bar -->
    <View
        android:id="@+id/view_top_bar"
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_voice_overlay_handle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top row: switch IME, status label, settings -->
    <ImageButton
        android:id="@+id/btn_previous_ime"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_keyboard_borderless"
        android:contentDescription="@string/btn_previous_ime_hint"
        android:padding="6dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_keyboard_switch_ime"
        android:tint="@color/keyboard_foreground_secondary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/view_top_bar" />

    <TextView
        android:id="@+id/label_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/whisper_to_input"
        android:textColor="@color/keyboard_foreground"
        android:textSize="15sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintBottom_toBottomOf="@+id/btn_previous_ime"
        app:layout_constraintEnd_toStartOf="@+id/btn_settings"
        app:layout_constraintStart_toEndOf="@+id/btn_previous_ime"
        app:layout_constraintTop_toTopOf="@+id/btn_previous_ime" />

    <ImageButton
        android:id="@+id/btn_settings"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_keyboard_borderless"
        android:contentDescription="@string/btn_settings_hint"
        android:padding="6dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_keyboard_settings"
        android:tint="@color/keyboard_foreground_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btn_previous_ime" />

    <!-- Waveform area: contains waveform view + side buttons -->
    <FrameLayout
        android:id="@+id/waveform_container"
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_keyboard_waveform"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_previous_ime">

        <com.example.whispertoinput.accessibility.WaveformView
            android:id="@+id/keyboard_waveform_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:contentDescription="@string/start_speech_to_text"
            android:focusable="false" />

        <!-- Mic icon overlay shown in idle state -->
        <ImageView
            android:id="@+id/keyboard_mic_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:clickable="false"
            android:contentDescription="@null"
            android:focusable="false"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_keyboard_mic"
            android:tint="@color/keyboard_accent" />

        <!-- Progress bar for transcribing state -->
        <ProgressBar
            android:id="@+id/pb_waiting_icon"
            style="?android:attr/progressBarStyle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:clickable="false"
            android:focusable="false"
            android:importantForAccessibility="no"
            android:visibility="invisible" />

    </FrameLayout>

    <!-- Cancel button (left of waveform, overlaid) -->
    <ImageButton
        android:id="@+id/btn_cancel"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_keyboard_borderless"
        android:contentDescription="@string/btn_cancel_hint"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_keyboard_cancel"
        android:tint="@color/keyboard_foreground_secondary"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="@+id/waveform_container"
        app:layout_constraintStart_toStartOf="@+id/waveform_container"
        app:layout_constraintTop_toTopOf="@+id/waveform_container" />

    <!-- Retry button (left of waveform, same position as cancel) -->
    <ImageButton
        android:id="@+id/btn_retry"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_keyboard_borderless"
        android:contentDescription="@string/btn_retry_hint"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_keyboard_retry"
        android:tint="@color/keyboard_foreground_secondary"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="@+id/waveform_container"
        app:layout_constraintStart_toStartOf="@+id/waveform_container"
        app:layout_constraintTop_toTopOf="@+id/waveform_container" />

    <!-- Backspace button (right of waveform, overlaid) -->
    <com.example.whispertoinput.keyboard.BackspaceButton
        android:id="@+id/btn_backspace"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_keyboard_borderless"
        android:contentDescription="@string/backspace_button_hint"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_keyboard_backspace"
        android:tint="@color/keyboard_foreground_secondary"
        app:layout_constraintBottom_toBottomOf="@+id/waveform_container"
        app:layout_constraintEnd_toEndOf="@+id/waveform_container"
        app:layout_constraintTop_toTopOf="@+id/waveform_container" />

    <!-- Bottom row: space bar + enter -->
    <ImageButton
        android:id="@+id/btn_space_bar"
        android:layout_width="0dp"
        android:layout_height="42dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_keyboard_space_bar"
        android:contentDescription="@string/desc_space_bar"
        android:scaleType="fitCenter"
        android:src="@drawable/btn_space_bar"
        android:tint="@color/keyboard_foreground_secondary"
        app:layout_constraintEnd_toStartOf="@+id/btn_enter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/waveform_container" />

    <ImageButton
        android:id="@+id/btn_enter"
        android:layout_width="56dp"
        android:layout_height="42dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_keyboard_button"
        android:contentDescription="@string/start_transcribing"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_keyboard_enter"
        android:tint="@color/keyboard_foreground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/waveform_container" />

</androidx.constraintlayout.widget.ConstraintLayout>
